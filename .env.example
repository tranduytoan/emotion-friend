# =============================================================================
# Emotion Friend — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in real values:
#
#   copy .env.example .env        (Windows)
#   cp .env.example .env          (Linux/Mac)
#
# NEVER commit .env to Git — it is already in .gitignore.
# =============================================================================

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=emotion_friend

# ── Backend ───────────────────────────────────────────────────────────────────
# HTTP port inside container (Nginx proxies :80 → backend:8080)
PORT=8080

# Admin panel token — change this before exposing to LAN
ADMIN_TOKEN=emotion-admin-change-me

# ── Android App ───────────────────────────────────────────────────────────────
# URL the Android app uses to reach the backend.
# Emulator (default) : http://10.0.2.2:80
# Physical device    : http://<YOUR_LAN_IP>:80   e.g. http://192.168.1.100:80
BACKEND_URL=http://10.0.2.2:80

# ── OpenAI (optional — for emotion AI features) ───────────────────────────────
OPENAI_API_KEY=
