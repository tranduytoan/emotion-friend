<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme — Compose handles all UI theming at runtime.
         This XML theme is used only for the activity window background during startup. -->
    <style name="Theme.EmotionFriend" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
