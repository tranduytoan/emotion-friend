# Server deployment environment
# Copy this file to .env on the Ubuntu server and fill in real values.

MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=emotion_friend
ADMIN_TOKEN=emotion-admin-change-me

# Images pulled from Docker Hub
# Use the same repository with role-specific tags.
BACKEND_IMAGE=trungnghia2703/emotion-friend:backend-latest
ADMIN_WEB_IMAGE=trungnghia2703/emotion-friend:admin-web-latest
