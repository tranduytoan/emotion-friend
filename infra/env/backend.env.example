# =============================================================================
# Emotion Friend — Backend Environment Variables (Template)
# =============================================================================
# Sao chép file này thành `backend.env` và điền giá trị thực tế.
# KHÔNG commit file `backend.env` vào Git.
# =============================================================================

# Cổng server Ktor sẽ lắng nghe
PORT=8080

# --- Kết nối Database (JDBC URL) ---
# Khi chạy qua Docker Compose, điền đầy đủ JDBC URL theo định dạng dưới.
# Thay `mysql` bằng service name trong docker-compose.yml.
DATABASE_URL=jdbc:mysql://mysql:3306/emotion_friend?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DATABASE_USER=emotion_user
DATABASE_PASSWORD=emotion_password
