# =============================================================================
# Emotion Friend — Backend Environment Variables (Template)
# =============================================================================
# Sao chép file này thành `backend.env` và điền giá trị thực tế.
# KHÔNG commit file `backend.env` vào Git.
# =============================================================================

# Môi trường chạy: development | production
APP_ENV=development

# Cổng server Ktor sẽ lắng nghe
SERVER_PORT=8080

# --- Kết nối Database ---
# Khi chạy qua Docker Compose, DB_HOST trỏ tới tên service MySQL trong docker-compose.yml
DB_HOST=mysql
DB_PORT=3306
DB_NAME=emotion_friend
DB_USER=emotion_user
DB_PASSWORD=emotion_password
