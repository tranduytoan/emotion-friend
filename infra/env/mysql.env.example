# =============================================================================
# Emotion Friend — MySQL Environment Variables (Template)
# =============================================================================
# Sao chép file này thành `mysql.env` và điền giá trị thực tế.
# KHÔNG commit file `mysql.env` vào Git.
# =============================================================================

# Tên database sẽ được tự động tạo khi container MySQL khởi động lần đầu
MYSQL_DATABASE=emotion_friend

# User ứng dụng — backend dùng user này để kết nối (không dùng root)
MYSQL_USER=emotion_user
MYSQL_PASSWORD=emotion_password

# Mật khẩu root — chỉ dùng cho quản trị thủ công, không để backend dùng
MYSQL_ROOT_PASSWORD=root_password
